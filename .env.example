# Shared database DSN for compose services.
POSTGRES_PASSWORD=
DATABASE_URL=postgresql+psycopg://layertrace:<POSTGRES_PASSWORD>@postgres:5432/layertrace
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# Local API auth; set a non-default token before running compose.
LAYERTRACE_API_TOKEN=
LAYERTRACE_REQUIRE_API_TOKEN=true

# Celery task runner keeps API requests separate from worker execution.
LAYERTRACE_TASK_RUNNER=celery
LAYERTRACE_LOG_LEVEL=INFO

# Browser origins cover Vite preview, Vite dev, and the composed frontend port.
LAYERTRACE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173,http://localhost:5173,http://127.0.0.1:5173
VITE_LAYERTRACE_API_BASE_URL=http://localhost:8080
VITE_LAYERTRACE_ALLOW_DEMO_FALLBACK=false
